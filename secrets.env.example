# =============================================================================
# secrets.env — Source this file before running provision.py
# =============================================================================
# DO NOT COMMIT THIS FILE. Add secrets.env to .gitignore.
# Copy this file to secrets.env and fill in your values.
# =============================================================================

# Required: SSH public key to inject into all VMs
export VM_SSH_PUBKEY="ssh-ed25519 AAAA... your-email@example.com"

# Optional: Password hash for console login fallback
# Generate with: mkpasswd -m sha-512
# If unset, password login is disabled (SSH key only).
# export VM_DEFAULT_PASSWORD='$6$rounds=4096$salt$hash...'